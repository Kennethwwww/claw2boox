# OpenClaw Gateway connection
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18789
GATEWAY_PASSWORD=

# Dashboard server
DASHBOARD_PORT=3000

# Admin token for generating pair codes (leave empty to allow unauthenticated access)
ADMIN_TOKEN=

# Refresh interval for the dashboard (milliseconds, default: 5 minutes)
REFRESH_INTERVAL_MS=300000
